{
  "extends": "@trshcmpctr/typescript",

  "compilerOptions": {
    // Leave JSX transformation to Babel
    "jsx": "preserve",

    // Package code is resolved by Webpack
    // "moduleResolution" is "bundler" by default if "module" is "preserve"
    "module": "preserve",

    // Package is built with Babel
    "noEmit": true,

    // Package is built with Babel, Node 24.16.8 supports virtually all features ES2025 and below:
    // <https://node.green/#ES2025>
    "target": "es2025",

    "types": [
      "node"
    ]
  },

  "include": [
    "src",
    // jest-setup.ts needs to be .ts to include @testing-library/jest-dom types
    "./jest-setup.ts"
  ]
}
