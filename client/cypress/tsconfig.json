{
  "extends": "@trshcmpctr/typescript",

  "compilerOptions": {
    // Preserve ESM imports and CommonJS requires as-is.
    // Best reflects capabilities of bundlers.
    "module": "preserve",

    // Only include some visible @types in compilation
    "types": [
      "node",
      "cypress"
    ]
  },

  "include": [
    "./cypress.config.ts",
    "e2e",
    "support"
  ]
}
